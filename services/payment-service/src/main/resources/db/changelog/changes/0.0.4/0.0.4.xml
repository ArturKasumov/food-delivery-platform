<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="0.0.4-1" author="arturk">
        <addColumn tableName="checkout_jobs">
            <column name="retry_attempt" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="next_attempt_at" type="timestamp"/>
            <column name="last_error" type="text"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="checkout_jobs" columnName="retry_attempt"/>
            <dropColumn tableName="checkout_jobs" columnName="next_attempt_at"/>
            <dropColumn tableName="checkout_jobs" columnName="last_error"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
